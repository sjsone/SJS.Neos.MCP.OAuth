prototype(SJS.Neos.MCP.OAuth:Module.OAuthClient.Action.Tokens) < prototype(Neos.Fusion:Component) {
    client = ${client}
    tokens = ${tokens}

    renderer = afx`
        <SJS.Neos.MCP.OAuth:Module.Component.OAuthClient.Tokens
            client={props.client}
            tokens={props.tokens}
            cancelAction="party"
            cancelArguments={{party: props.client.party}}
        />
    `
}
